            </mxCell>
            
        <mxCell id="6" value="Else Largest = C" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
        <mxGeometry x="240" y="480" width="120" height="60" as="geometry"/>
        </mxCell>
        
            <mxCell id="106" style="endArrow=block;html=1;" edge="1" parent="1" source="5" target="6">
            <mxGeometry relative="1" as="geometry"/>
            </mxCell>
            
        <mxCell id="7" value="Display largest" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
        <mxGeometry x="240" y="580" width="120" height="60" as="geometry"/>
        </mxCell>
        
            <mxCell id="107" style="endArrow=block;html=1;" edge="1" parent="1" source="6" target="7">
