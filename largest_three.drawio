        </mxCell>
        
            <mxCell id="103" style="endArrow=block;html=1;" edge="1" parent="1" source="2" target="3">
            <mxGeometry relative="1" as="geometry"/>
            </mxCell>
            
        <mxCell id="4" value="If A >= B and A >= C then Largest = A" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
        <mxGeometry x="240" y="280" width="120" height="60" as="geometry"/>
        </mxCell>
        
            <mxCell id="104" style="endArrow=block;html=1;" edge="1" parent="1" source="3" target="4">
            <mxGeometry relative="1" as="geometry"/>
            </mxCell>
            
        <mxCell id="5" value="Else if B >= A and B >= C then Largest = B" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
        <mxGeometry x="240" y="380" width="120" height="60" as="geometry"/>
        </mxCell>
        
            <mxCell id="105" style="endArrow=block;html=1;" edge="1" parent="1" source="4" target="5">
